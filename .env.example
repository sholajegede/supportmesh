# Kinde OAuth app credentials — found in your Kinde dashboard under Applications
KINDE_CLIENT_ID=
KINDE_CLIENT_SECRET=

# Your Kinde tenant domain (e.g. https://myapp.kinde.com)
KINDE_ISSUER_URL=https://yourapp.kinde.com

# The URL of this Next.js app (use http://localhost:3000 for local dev)
KINDE_SITE_URL=http://localhost:3000

# Where Kinde redirects after logout
KINDE_POST_LOGOUT_REDIRECT_URL=http://localhost:3000

# Where Kinde redirects after a successful login
KINDE_POST_LOGIN_REDIRECT_URL=http://localhost:3000/dashboard

# Anthropic API key for the Mastra AI agents
ANTHROPIC_API_KEY=

# Kinde domain — same value as KINDE_ISSUER_URL, used by the management API client
KINDE_DOMAIN=https://yourapp.kinde.com

# Kinde API audience — found in your Kinde dashboard under APIs
KINDE_AUDIENCE=

# Convex deployment URL — found in your Convex dashboard after running `npx convex dev`
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# Optional API key for the public REST API and MCP server (/api/v1, /api/mcp)
# When set, all requests must include: Authorization: Bearer <key> or ?apiKey=<key>
# Leave empty for demo mode (no key required)
SUPPORTMESH_API_KEY=

# ── Kinde Auth ──────────────────────────────────────────────────────────────
# OAuth app client ID — found in your Kinde dashboard under Applications
KINDE_CLIENT_ID=

# OAuth app client secret
KINDE_CLIENT_SECRET=

# Your Kinde tenant domain (e.g. https://myapp.kinde.com)
# Used to construct the JWKS URL for verifying Kinde webhook JWTs
KINDE_ISSUER_URL=https://yourapp.kinde.com

# Same value as KINDE_ISSUER_URL — used by the Mastra auth integration
KINDE_DOMAIN=https://yourapp.kinde.com

# URL of this Next.js app — used by the Kinde SDK for OAuth callbacks
KINDE_SITE_URL=http://localhost:3000

# Where Kinde redirects after logout
KINDE_POST_LOGOUT_REDIRECT_URL=http://localhost:3000

# Where Kinde redirects after a successful login
KINDE_POST_LOGIN_REDIRECT_URL=http://localhost:3000/dashboard

# ── AI ───────────────────────────────────────────────────────────────────────
# Anthropic API key — used by the @ai-sdk/anthropic provider powering the triage and summary agents
ANTHROPIC_API_KEY=

# ── Convex ───────────────────────────────────────────────────────────────────
# Convex deployment URL — written automatically by `npx convex dev`
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# Convex HTTP actions base URL (format: https://your-deployment.convex.site)
# The Kinde webhook endpoint is: ${NEXT_PUBLIC_CONVEX_SITE_URL}/kinde
NEXT_PUBLIC_CONVEX_SITE_URL=https://your-deployment.convex.site

# Set automatically by `npx convex deploy` and `npx convex dev` — do not fill in manually
# CONVEX_DEPLOYMENT=

# ── Email ────────────────────────────────────────────────────────────────────
# Resend API key for sending email responses to customers (optional)
RESEND_API_KEY=
